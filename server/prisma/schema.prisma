generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ServiceType {
  TAXI
  BIKE
  DELIVERY
}

enum VehicleType {
  CAR4
  CAR6
  PREMIUM
}

enum BookingStatus {
  PENDING
  ACCEPTED
  ONGOING
  COMPLETED
  CANCELLED
}

model User {
  id                     String    @id @default(cuid())
  name                   String
  email                  String    @unique
  password               String
  phone                  String?
  role                   String    @default("USER")
  isActive               Boolean   @default(true)
  isBlocked              Boolean   @default(false)
  blockedReason          String?
  blockedAt              DateTime?
  resetPasswordToken     String?
  resetPasswordExpiresAt DateTime?
  bookings               Booking[]
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model Driver {
  id          String    @id @default(cuid())
  name        String
  phone       String?
  vehicleName String
  plateNumber String    @unique
  isActive    Boolean   @default(true)
  notes       String?
  bookings    Booking[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Booking {
  id                 String        @id @default(cuid())
  userId             String?
  user               User?         @relation(fields: [userId], references: [id])

  driverId           String?
  driver             Driver?       @relation(fields: [driverId], references: [id])

  serviceType        ServiceType
  vehicleType        VehicleType?
  pickupAddress      String
  destinationAddress String
  distanceKm         Float
  baseFare           Int
  perKm              Int
  minimumFare        Int
  calculatedPrice    Int
  finalPrice         Int
  etaMinutes         Int
  status             BookingStatus @default(PENDING)
  note               String?
  paymentMethod      String        @default("CASH")
  cancelReason       String?
  isScheduled        Boolean       @default(false)
  scheduledAt        DateTime?
  driverName         String?
  driverPhone        String?
  vehicleName        String?
  plateNumber        String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model PricingRule {
  id          String   @id @default(cuid())
  section     String
  key         String   @unique
  label       String
  baseFare    Int
  perKm       Int
  minimumFare Int
  etaBase     Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}